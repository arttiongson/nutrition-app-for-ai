# Copy to `.env` and fill in real values. `.env` is gitignored — never commit it.
# These are the only secrets the project needs. Different runtimes read different
# subsets (see comments), but one template keeps it simple.

# ── Supabase (project → Settings → API) ──────────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# Publishable key: safe to ship in the iOS app / browser. RLS is what protects data.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
# Secret key: SERVER ONLY. Bypasses RLS. Never ship to a client or commit it.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx

# ── AI meal parser — used ONLY server-side in the /log Edge Function ──────
# Stored as a Supabase secret in production (`supabase secrets set GEMINI_API_KEY=...`),
# never in the app or the MCP server.
GEMINI_API_KEY=your_gemini_api_key_here
